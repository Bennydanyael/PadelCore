@using PadelScore.Components.Layout
@using PadelScore.Utils.Containers

@inject NavigationState NavState
@inject NavigationManager NavigationManager

<Router AppAssembly="@typeof(MauiProgram).Assembly">
    <Found>
        <MainLayout />
    </Found>
    <NotFound>
        <div style="padding:20px; background:#050B14; min-height:100vh; color:white;">
            <h1>404 - Page Not Found</h1>
        </div>
    </NotFound>
</Router>

