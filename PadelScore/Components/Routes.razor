@code {
    protected override void OnInitialized()
    {
        NavState.OnChange += StateHasChanged;
        NavigationManager.LocationChanged += OnLocationChanged;

        UpdateNavStateFromUri(NavigationManager.Uri);
        base.OnInitialized();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateNavStateFromUri(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private void UpdateNavStateFromUri(string uri)
    {
        var baseUri = NavigationManager.BaseUri;
        var relative = uri.Replace(baseUri, "/");
        var tab = relative.Trim('/').ToLowerInvariant();
        if (string.IsNullOrEmpty(tab)) tab = "home";

        switch (tab)
        {
            case "":
            case "/":
            case "home":
                NavState.NavigateTo("home");
                break;
            case "courts":
                NavState.NavigateTo("courts");
                break;
            case "book":
                NavState.NavigateTo("book");
                break;
            case "mygames":
                NavState.NavigateTo("mygames");
                break;
            case "passes":
                NavState.NavigateTo("passes");
                break;
            default:
                // leave as-is
                break;
        }
    }

    public void Dispose()
    {
        NavState.OnChange -= StateHasChanged;
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
