@using PadelScore.Components.Layout
@using PadelScore.Utils.Containers

@inject NavigationState NavState
@inject NavigationManager NavigationManager

<Router AppAssembly="@typeof(MauiProgram).Assembly">
    <Found>
        <MainLayout />
    </Found>
    <NotFound>
        <div style="padding:20px; background:#050B14; min-height:100vh; color:white;">
            <h1>404 - Page Not Found</h1>
        </div>
    </NotFound>
</Router>

@code {
    protected override void OnInitialized()
    {
        NavState.OnChange += StateHasChanged;
        NavigationManager.LocationChanged += OnLocationChanged;

        UpdateNavStateFromUri(NavigationManager.Uri);
        base.OnInitialized();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateNavStateFromUri(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private void UpdateNavStateFromUri(string uri)
    {
        var baseUri = NavigationManager.BaseUri;
        var relative = uri.Replace(baseUri, "/");
        var tab = relative.Trim('/').ToLowerInvariant();
        if (string.IsNullOrEmpty(tab)) tab = "home";

        switch (tab)
        {
            case "":
            case "/":
            case "home":
                NavState.NavigateTo("home");
                break;
            case "courts":
                NavState.NavigateTo("courts");
                break;
            case "book":
                NavState.NavigateTo("book");
                break;
            case "mygames":
                NavState.NavigateTo("mygames");
                break;
            case "passes":
                NavState.NavigateTo("passes");
                break;
            default:
                break;
        }
    }

    public void Dispose()
    {
        NavState.OnChange -= StateHasChanged;
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
