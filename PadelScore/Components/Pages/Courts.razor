@code {
    [Parameter] public EventCallback<string> OnNavigate { get; set; }
    private string _color = "";
    private string SelectedFilter = "all";
    private List<Court> FilteredCourts => SelectedFilter == "all" 
        ? Data.CourtsPage
        : Data.CourtsPage.Where(c => c.Categories.Contains(SelectedFilter)).ToList();
    
    private List<(string Key, string Label)> Filters = new()
    {
        ("all", "All"),
        ("Indoor", "Indoor"),
        ("Outdoor", "Outdoor"),
        ("Glass Wall", "Glass Wall"),
        ("Premium", "Premium")
    };

    private void NavigateBack()
    {
        NavState.NavigateTo("home");
    }

    private void NavigateToBook()
    {
        NavState.NavigateTo("book");
    }
}