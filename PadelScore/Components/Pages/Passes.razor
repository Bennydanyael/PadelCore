@code {
    [Parameter] public EventCallback<string> OnNavigate { get; set; }
    private string _color = "";
    private User User => Data.User;
    private Pass? SelectedPass;
    private bool CanBuyPass => SelectedPass != null;
    private void BuyPass()
    {
        if (SelectedPass != null)
        {
            Console.WriteLine($"Buying {SelectedPass.Name} pass");
        }
    }
    private async Task NavigateHome()
    {
        NavState.NavigateTo("home");
    }

    private string GetBackgroundColor(Pass pass)
    {
        if (string.IsNullOrEmpty(pass.Color)) return "rgba(255,255,255,0.3)";
        if (pass.Color.StartsWith("rgb("))
        {
            var match = Regex.Match(pass.Color, @"rgb\((\d+),\s*(\d+),\s*(\d+)\)");
            if (match.Success)
            {
                var r = match.Groups[1].Value;
                var g = match.Groups[2].Value;
                var b = match.Groups[3].Value;
                return $"rgba({r}, {g}, {b}, 0.3)"; 
            }
        }
        if (pass.Color.StartsWith("rgba("))
        {
            return Regex.Replace(pass.Color, @"0\.\d+", "0.6");
        }

        return "rgba(255,255,255,0.3)";
    }

    private double GetProgressPercentage()
    {
        return Data.User.Pass.TotalSessions > 0 
            ? (double)Data.User.Pass.UsedSessions / Data.User.Pass.TotalSessions * 100 
            : 0;
    }
    private void SelectPass(Pass pass)
    {
        SelectedPass = SelectedPass?.Name == pass.Name ? null : pass;
        StateHasChanged();
    }
}