                              PerSessionPrice="@pass.PerSessionPrice"
                              Validity="@pass.Validity"
                              Features="@pass.Features"
                              Color="@pass.Color"
                              BackgroundColor="@GetBackgroundColor(pass)"
                              ImagePath="@pass.ImagePath"
                              IsBestValue="@pass.IsBestValue"
                              IsSelected="@(SelectedPass?.Name == pass.Name)"
