@* Court Icon with Padel Racket and Ball *@
<div class="court-icon @(IsAvailable ? "available" : "unavailable")">
    <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Background circle -->
        <circle cx="20" cy="20" r="18" fill="@(IsAvailable ? "rgba(34, 211, 238, 0.12)" : "rgba(255, 255, 255, 0.04)")"
                stroke="@(IsAvailable ? "rgba(34, 211, 238, 0.3)" : "rgba(255, 255, 255, 0.06)")"
                stroke-width="1.5" />

        <!-- Padel Racket -->
        <g transform="translate(12, 8)">
            <!-- Racket handle -->
            <rect x="7.5" y="14" width="2" height="8" rx="1" fill="@(IsAvailable ? "#22D3EE" : "rgba(255,255,255,0.2)")" />
            <!-- Racket head -->
            <ellipse cx="8.5" cy="8" rx="7" ry="8" fill="@(IsAvailable ? "#22D3EE" : "rgba(255,255,255,0.15)")"
                     stroke="@(IsAvailable ? "#06B6D4" : "rgba(255,255,255,0.05)")" stroke-width="1" />
            <!-- Racket strings -->
            <line x1="4" y1="4" x2="13" y2="4" stroke="@(IsAvailable ? "rgba(255,255,255,0.4)" : "rgba(255,255,255,0.05)")" stroke-width="0.5" />
            <line x1="4" y1="6" x2="13" y2="6" stroke="@(IsAvailable ? "rgba(255,255,255,0.4)" : "rgba(255,255,255,0.05)")" stroke-width="0.5" />
            <line x1="4" y1="8" x2="13" y2="8" stroke="@(IsAvailable ? "rgba(255,255,255,0.4)" : "rgba(255,255,255,0.05)")" stroke-width="0.5" />
            <line x1="4" y1="10" x2="13" y2="10" stroke="@(IsAvailable ? "rgba(255,255,255,0.4)" : "rgba(255,255,255,0.05)")" stroke-width="0.5" />
            <line x1="4" y1="12" x2="13" y2="12" stroke="@(IsAvailable ? "rgba(255,255,255,0.4)" : "rgba(255,255,255,0.05)")" stroke-width="0.5" />
        </g>

        <!-- Padel Ball -->
        <g transform="translate(22, 18)">
            <circle cx="4" cy="4" r="3.5" fill="@(IsAvailable ? "#A3E635" : "rgba(255,255,255,0.1)")"
                    stroke="@(IsAvailable ? "#84CC16" : "rgba(255,255,255,0.03)")" stroke-width="0.5" />
            <!-- Ball texture lines -->
            <path d="M2 2 L6 6" stroke="@(IsAvailable ? "rgba(255,255,255,0.4)" : "rgba(255,255,255,0.05)")" stroke-width="0.5" />
            <path d="M6 2 L2 6" stroke="@(IsAvailable ? "rgba(255,255,255,0.4)" : "rgba(255,255,255,0.05)")" stroke-width="0.5" />
            <path d="M4 1 L4 7" stroke="@(IsAvailable ? "rgba(255,255,255,0.3)" : "rgba(255,255,255,0.03)")" stroke-width="0.5" />
            <path d="M1 4 L7 4" stroke="@(IsAvailable ? "rgba(255,255,255,0.3)" : "rgba(255,255,255,0.03)")" stroke-width="0.5" />
            <!-- Ball shine -->
            <circle cx="3" cy="3" r="1" fill="rgba(255,255,255,0.2)" />
        </g>
    </svg>
</div>

<style>
    
</style>

@code {
    [Parameter] public bool IsAvailable { get; set; } = true;
}