@using PadelScore.Components.Shared
@using PadelScore.Utils.Tokens

<div class="court-card @(Compact ? "home-compact" : "")" style="background:@(Background ?? Court.ColorBackground)">
	@if (Compact)
	{
		<div class="court-image-wrapper home-top-image">
			<img src="@Court.PathImage" alt="@Court.Name" class="court-image" />
		</div>
		<div class="court-body">
			<div class="court-name-row">
				<h3>@Court.Name</h3>
				@if (ShowAvailability)
				{
					@if (Court.IsAvailable)
					{
						<span class="availability-dot available"></span>
					}
					else
					{
						<span class="availability-dot unavailable"></span>
					}
				}
			</div>
			<div class="court-details">
				<span class="court-type">@Court.Type</span>
				<span class="court-surface">@Court.Surface</span>
			</div>
		</div>
	}
	else
	{
		<div class="court-header">
			<div class="court-image-wrapper">
				<img src="@Court.PathImage" alt="@Court.Name" class="court-image" />
			</div>
			<div class="court-title">
				<div class="court-name-row">
					<h3>@Court.Name</h3>
					@if (ShowAvailability)
					{
						@if (Court.IsAvailable)
						{
							<span class="availability-dot available"></span>
						}
						else
						{
							<span class="availability-dot unavailable"></span>
						}
					}
				</div>
				<div class="court-details">
					<span class="court-type">@Court.Type</span>
					<span class="court-surface">@Court.Surface</span>
				</div>
			</div>
		</div>
	}

	@if (ShowFooter)
	{
		<div class="court-footer">
			<div class="price-section">
				<div class="price-item">
					<span class="price">@Formatter.FormatCurrency(Court.Price)</span>
					<span class="price-period">/hr</span>
				</div>
			</div>
			<PrimaryButton Disabled="!Court.IsAvailable" OnClick="() => OnBook.InvokeAsync(Court)">
				@(Court.IsAvailable ? (ButtonText ?? "Book Now") : "Fully Booked")
			</PrimaryButton>
		</div>
	}
</div>

@code {
	[Parameter] public Court Court { get; set; } = default!;
	[Parameter] public EventCallback<Court> OnBook { get; set; }
	[Parameter] public bool ShowFooter { get; set; } = true;
	[Parameter] public bool ShowAvailability { get; set; } = true;
	[Parameter] public bool Compact { get; set; } = false;
	[Parameter] public string? ButtonText { get; set; }
	[Parameter] public string? Background { get; set; }
}
