<div class="pass-card" style="background:rgba(0, 255, 255, 0.05)">
    <div class="pass-header">
        <div class="pass-header-left">
            <span class="section-eyebrow">CURRENT PASS</span>
            <span class="pass-name">@PassName</span>
        </div>
        <div class="pass-header-right">
            @if (UseImagePath)
            {
                <div class="court-image-wrapper">
                    <img src="@ImagePath" alt="Pass" class="court-image" />
                </div>
            }
            <span class="pass-status @(IsActive ? "active" : "inactive")">
                @(IsActive ? "Active" : "Inactive")
            </span>
        </div>
    </div>
    
    <div class="pass-progress">
        <div class="progress-labels">
            <span>Sessions used</span>
            <span>@UsedSessions / @TotalSessions</span>
        </div>
        <div class="progress-bar">
            <div class="progress-fill" style="width: 0%"></div>
        </div>
        @if (UseSessionDot)
        {
            <div class="session-dots">
                @for (int i = 0; i < TotalSessions; i++)
                {
                    <div class="session-dot @(i < UsedSessions ? "filled" : "empty")"></div>
                }
            </div>
        }
    </div>
    
    <div class="pass-footer">
        <div class="pass-footer-left">
            @if (IsUsedIconCalendar)
            {
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 9H21M7 3V5M17 3V5M6 12H8M11 12H13M16 12H18M6 15H8M11 15H13M16 15H18M6 18H8M11 18H13M16 18H18M6.2 21H17.8C18.9201 21 19.4802 21 19.908 20.782C20.2843 20.5903 20.2843 20.5903 20.782 19.908C21 19.4802 21 18.9201 21 17.8V8.2C21 7.07989 21 6.51984 20.782 6.09202C20.5903 5.71569 20.2843 5.40973 19.908 5.21799C19.4802 5 18.9201 5 17.8 5H6.2C5.0799 5 4.51984 5 4.09202 5.21799C3.71569 5.40973 3.40973 5.71569 3.21799 6.09202C3 6.51984 3 7.07989 3 8.2V17.8C3 18.9201 3 19.4802 3.21799 19.908C3.40973 20.2843 3.71569 20.5903 4.09202 20.782C4.51984 21 5.07989 21 6.2 21Z"
                      stroke="rgb(151, 151, 151)" stroke-width="1.5" stroke-linecap="round" />
            </svg>
            <span class="expiry-label">Valid until @ExpiryDate</span>
            }else
            {
                <span class="expiry-label">Expires @ExpiryDate</span>
            }
        </div>
        <div class="pass-footer-right">
            @if (IsUsedButton)
            {
            <span class="sessions-left-passes">@RemainingSessions left</span>
            }else
            {
                <button class="buy-more-btn" @onclick="async () => await OnBuyMore.InvokeAsync(Pass)">
                    Buy More >
                </button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public UserPass Pass { get; set; } = default!;
    [Parameter] public string PassName { get; set; } = "Regular Pass";
    [Parameter] public int TotalSessions { get; set; } = 10;
    [Parameter] public int UsedSessions { get; set; } = 2;
    [Parameter] public string ExpiryDate { get; set; } = string.Empty;
    [Parameter] public bool IsActive { get; set; } = true;
    [Parameter] public string ImagePath { get; set; } = "Images/CourtsA.png";
    [Parameter] public EventCallback<UserPass> OnBuyMore { get; set; }
    [Parameter] public bool UseSessionDot { get; set; } = false;
    [Parameter] public bool UseImagePath { get; set; } = false;
    [Parameter] public bool IsUsedIconCalendar { get; set; } = false;
    [Parameter] public bool IsUsedButton { get; set; } = false;
    private double ProgressPercentage => TotalSessions > 0 ? (double)UsedSessions / TotalSessions * 100 : 0;
    private int RemainingSessions => TotalSessions - UsedSessions;
}