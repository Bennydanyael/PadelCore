<div class="screen-header">
	<div class="left">
		@if (LeftContent != null)
		{
			@LeftContent
		}
	</div>
	<div class="center">
		@if(IsHomeHeader.Equals("true", StringComparison.Ordinal))
		{
			@if(!string.IsNullOrEmpty(UseIcon) || !string.IsNullOrEmpty(UseIconText))
			{
				 <span class="location-icon-courts">
					 @if(!string.IsNullOrEmpty(UseIcon))
					 {
						 <svg width="12" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="@UseIcon" />
							<circle cx="12" cy="10" r="3" />
						</svg>
					 }
					 <span class="location-text">@UseIconText</span>
				</span>
			}
		}else
		{
			<div class="title">@Title</div>
		}
		@if(IsHomeHeader.Equals("false", StringComparison.Ordinal))
		{
			@if(!string.IsNullOrEmpty(UseIcon) || !string.IsNullOrEmpty(UseIconText))
			{
				 <span class="location-icon-courts">
					 @if(!string.IsNullOrEmpty(UseIcon))
					 {
						 <svg width="12" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="@UseIcon" />
							<circle cx="12" cy="10" r="3" />
						</svg>
					 }
					 <span class="location-text">@UseIconText</span>
				</span>
			}
			@if (!string.IsNullOrEmpty(Subtitle))
			{
				<div class="subtitle">@Subtitle</div>
			}
		}
	</div>
	<div class="right">
		@if (RightContent != null)
		{
			@RightContent
		}
	</div>
</div>

@code {
	[Parameter] public string IsHomeHeader { get; set; } = "false";
	[Parameter] public string Title { get; set; } = string.Empty;
	[Parameter] public string Subtitle { get; set; } = string.Empty;
	[Parameter] public string UseIcon { get; set; } = string.Empty;
	[Parameter] public string UseIconText { get; set; } = string.Empty;
	[Parameter] public RenderFragment? LeftContent { get; set; }
	[Parameter] public RenderFragment? RightContent { get; set; }
}
